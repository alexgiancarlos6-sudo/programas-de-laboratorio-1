<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Validador de Carné</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="validator-card">
        <h2>Validador de Estudiante</h2>
        <p>Ingresa tu número de carné (Formato: 0000-00-000)</p>
        
        <input type="text" id="carnetInput" placeholder="Ej: 2024-05-123" maxlength="11">
        
        <button onclick="validateCarnet()">Verificar Estado</button>
        
        <div id="resultMessage" class="message"></div>
    </div>
    <script src="script.js"></script>
</body>
</html>
